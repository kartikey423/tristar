# Frontend Environment — copy to .env.local and fill in your token
#
# SETUP STEPS:
#   1. Make sure the backend is running:
#        uvicorn src.backend.main:app --reload --port 8000
#
#   2. Generate your MARKETER_JWT (run from project root):
#        curl -s -X POST "http://localhost:8000/api/auth/demo-token?role=marketing" | python3 -m json.tool
#      Copy the "access_token" value from the response.
#
#   3. Copy this file:
#        cp src/frontend/.env.local.example src/frontend/.env.local
#
#   4. Replace REPLACE_WITH_YOUR_TOKEN below with the access_token you copied.
#
#   5. Restart the frontend:
#        cd src/frontend && npm run dev
#
# Token is valid for 100 hours — regenerate if you get 401 errors.
# NEVER commit .env.local — it is gitignored.

MARKETER_JWT=REPLACE_WITH_YOUR_TOKEN
API_URL=http://localhost:8000
