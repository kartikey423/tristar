# TriStar Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# SETUP STEPS FOR A NEW MACHINE:
#
#  1. Copy this file to .env and fill in CLAUDE_API_KEY:
#       cp .env.example .env
#
#  2. Start the backend:
#       cd src/backend && uvicorn src.backend.main:app --reload --port 8000
#     (or from project root: uvicorn src.backend.main:app --reload --port 8000)
#
#  3. Generate a long-lived MARKETER_JWT (valid 100 hours):
#       curl -s -X POST "http://localhost:8000/api/auth/demo-token?role=marketing" | python3 -m json.tool
#     Copy the "access_token" value from the response.
#
#  4. Create src/frontend/.env.local with the token and backend URL:
#       echo "MARKETER_JWT=<paste token here>" > src/frontend/.env.local
#       echo "API_URL=http://localhost:8000"   >> src/frontend/.env.local
#
#  5. Start the frontend:
#       cd src/frontend && npm install && npm run dev
#
# NEVER commit .env or src/frontend/.env.local — they are gitignored.
# ─────────────────────────────────────────────────────────────────────────────

# ── Claude API ─────────────────────────────────────────────────────────────────
CLAUDE_API_KEY=sk-ant-...           # Required — get from console.anthropic.com
CLAUDE_MODEL=claude-sonnet-4-6
CLAUDE_MODEL_DEFAULT=claude-sonnet-4-6
CLAUDE_MODEL_HAIKU=claude-haiku-4-5-20251001
USE_PROMPT_CACHING=False

# ── Hub API (internal) ─────────────────────────────────────────────────────────
HUB_API_URL=http://localhost:8000/api/hub

# ── Inventory Data ─────────────────────────────────────────────────────────────
INVENTORY_FILE_PATH=data/inventory.csv

# ── JWT Auth ────────────────────────────────────────────────────────────────────
# JWT_SECRET must match the value used when generating the MARKETER_JWT token.
# All developers on the same team can share the same dev secret.
JWT_SECRET=dev-secret-change-in-prod
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=1
SERVICE_JWT_EXPIRY_HOURS=100       # Long-lived token for marketer demo (100h)

# ── Weather API ─────────────────────────────────────────────────────────────────
WEATHER_API_KEY=                   # Optional — leave blank to skip weather context

# ── Notifications ───────────────────────────────────────────────────────────────
NOTIFICATION_PROVIDER_URL=http://localhost:9000/notify

# ── Scout Webhook ───────────────────────────────────────────────────────────────
SCOUT_WEBHOOK_SECRET=dev-webhook-secret

# ── Feature Flags ────────────────────────────────────────────────────────────────
PURCHASE_TRIGGER_ENABLED=false
PURCHASE_TRIGGER_PILOT_MEMBERS=
PURCHASE_TRIGGER_SCORE_THRESHOLD=70.0

# ── Logging ──────────────────────────────────────────────────────────────────────
LOG_LEVEL=DEBUG
ENVIRONMENT=development
