# TriStar Environment Variables — copy to .env and fill in values
# NEVER commit .env to git

# ── Claude API ─────────────────────────────────────────────────────────────────
CLAUDE_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-6

# ── Hub API (internal) ─────────────────────────────────────────────────────────
HUB_API_URL=http://localhost:8000/api/hub

# ── Inventory Data ─────────────────────────────────────────────────────────────
INVENTORY_FILE_PATH=data/inventory.csv

# ── JWT Auth ────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=1
SERVICE_JWT_EXPIRY_HOURS=24

# ── Weather API ─────────────────────────────────────────────────────────────────
WEATHER_API_KEY=your-openweather-api-key

# ── Notifications ───────────────────────────────────────────────────────────────
NOTIFICATION_PROVIDER_URL=http://localhost:9000/notify

# ── Scout Webhook ───────────────────────────────────────────────────────────────
SCOUT_WEBHOOK_SECRET=change-me-in-production

# ── Feature Flags (F-009) ────────────────────────────────────────────────────────
# Set PURCHASE_TRIGGER_ENABLED=true in demo/production environments
PURCHASE_TRIGGER_ENABLED=false
# Comma-separated pilot member IDs; leave empty to enable for all members
PURCHASE_TRIGGER_PILOT_MEMBERS=

# ── Thresholds ───────────────────────────────────────────────────────────────────
PURCHASE_TRIGGER_SCORE_THRESHOLD=70.0
PURCHASE_TRIGGER_RATE_LIMIT_HOURS=6
OFFER_VALID_UNTIL_HOURS=4

# ── Logging ──────────────────────────────────────────────────────────────────────
LOG_LEVEL=DEBUG
ENVIRONMENT=development

# ── CORS ─────────────────────────────────────────────────────────────────────────
# CORS_ORIGINS=["http://localhost:3000"]
