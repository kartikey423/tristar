{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "clarification_questions.schema.json",
  "title": "Clarification Questions",
  "description": "Questions from Problem Decomposer when requirements are ambiguous",
  "type": "object",
  "additionalProperties": false,
  "required": ["clarification_needed", "questions"],
  "properties": {
    "clarification_needed": {
      "type": "boolean",
      "const": true,
      "description": "True when more input is required before writing a problem spec"
    },
    "questions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "question", "impact"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^Q[0-9]+$"
          },
          "question": {
            "type": "string"
          },
          "impact": {
            "type": "string"
          }
        }
      }
    },
    "notes": {
      "type": "string",
      "description": "Optional context or assumptions for the reviewer"
    }
  }
}
