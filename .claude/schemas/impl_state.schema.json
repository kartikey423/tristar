{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Implementation State",
  "description": "Mid-implementation checkpoint for session resumability. Tracks per-file progress during Phase 4.",
  "type": "object",
  "required": ["ticket_id", "started_at", "updated_at", "mode", "current_file_index", "total_files", "files_processed", "baseline_test_counts", "paused"],
  "properties": {
    "ticket_id": {
      "type": "string",
      "pattern": "^[A-Z]+-[0-9]+$",
      "description": "Jira ticket ID"
    },
    "started_at": {
      "type": "string",
      "description": "ISO 8601 timestamp when implementation started"
    },
    "updated_at": {
      "type": "string",
      "description": "ISO 8601 timestamp of last update"
    },
    "mode": {
      "type": "string",
      "enum": ["inline", "waves"],
      "description": "Implementation mode: inline (sequential) or waves (parallel)"
    },
    "current_file_index": {
      "type": "integer",
      "minimum": 0,
      "description": "Index of the current file being processed (0-based)"
    },
    "total_files": {
      "type": "integer",
      "minimum": 1,
      "description": "Total number of files to process"
    },
    "current_wave": {
      "type": ["integer", "null"],
      "minimum": 0,
      "description": "Current wave number (waves mode only, null for inline)"
    },
    "total_waves": {
      "type": ["integer", "null"],
      "minimum": 1,
      "description": "Total number of waves (waves mode only, null for inline)"
    },
    "files_processed": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "status"],
        "properties": {
          "path": {
            "type": "string",
            "description": "Relative file path"
          },
          "component_id": {
            "type": "string",
            "pattern": "^COMP-[0-9]{3}$",
            "description": "Design spec component ID"
          },
          "status": {
            "type": "string",
            "enum": ["completed", "failed", "skipped", "pending"],
            "description": "Processing status for this file"
          },
          "wave": {
            "type": ["integer", "null"],
            "description": "Wave number this file belongs to (null for inline mode)"
          },
          "test_counts_after": {
            "type": ["object", "null"],
            "properties": {
              "pass": { "type": "integer", "minimum": 0 },
              "fail": { "type": "integer", "minimum": 0 }
            },
            "required": ["pass", "fail"],
            "description": "Test counts after this file was processed"
          },
          "error": {
            "type": ["string", "null"],
            "description": "Error message if status is failed"
          }
        }
      },
      "description": "Per-file processing status"
    },
    "baseline_test_counts": {
      "type": "object",
      "required": ["pass", "fail"],
      "properties": {
        "pass": { "type": "integer", "minimum": 0 },
        "fail": { "type": "integer", "minimum": 0 }
      },
      "description": "Test counts before any implementation changes"
    },
    "paused": {
      "type": "boolean",
      "description": "Whether the implementation was paused mid-execution"
    }
  },
  "additionalProperties": false
}
