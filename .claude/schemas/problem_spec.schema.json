{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "problem_spec.schema.json",
  "title": "Problem Specification",
  "description": "Structured output from Problem Decomposer Agent",
  "type": "object",
  "additionalProperties": false,
  "required": ["meta", "problem_statement", "requirements", "constraints", "non_goals", "assumptions", "edge_cases"],
  "properties": {
    "meta": {
      "type": "object",
      "additionalProperties": false,
      "required": ["feature_id", "ticket_id", "created_at", "agent_version"],
      "properties": {
        "feature_id": {
          "type": "string",
          "pattern": "^FEAT-[0-9]{4}$",
          "description": "Unique feature identifier"
        },
        "ticket_id": {
          "type": "string",
          "description": "Jira ticket ID (e.g. {{JIRA_PREFIX}}-1234, PROJ-5678)"
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        },
        "agent_version": {
          "type": "string",
          "const": "2.0"
        },
        "source_ticket": {
          "type": "string",
          "description": "JIRA/GitHub issue reference"
        },
        "brands": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["BK", "PLK", "FHS", "TH"]
          },
          "description": "{{ORG_SHORT}} brands this feature applies to"
        }
      }
    },
    "problem_statement": {
      "type": "object",
      "additionalProperties": false,
      "required": ["summary", "user_problem", "business_value"],
      "properties": {
        "summary": {
          "type": "string",
          "maxLength": 200,
          "description": "One-line problem summary"
        },
        "user_problem": {
          "type": "string",
          "maxLength": 500,
          "description": "What user pain point does this solve?"
        },
        "business_value": {
          "type": "string",
          "maxLength": 500,
          "description": "Why does the business care?"
        }
      }
    },
    "requirements": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "type", "description", "priority", "acceptance_criteria"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^REQ-[0-9]{3}$"
          },
          "type": {
            "type": "string",
            "enum": ["functional", "non-functional", "technical"]
          },
          "description": {
            "type": "string",
            "maxLength": 300
          },
          "priority": {
            "type": "string",
            "enum": ["P0", "P1", "P2"],
            "description": "P0=must-have, P1=should-have, P2=nice-to-have"
          },
          "acceptance_criteria": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["id", "given", "when", "then"],
              "properties": {
                "id": {
                  "type": "string",
                  "pattern": "^AC-[0-9]{3}$"
                },
                "given": {
                  "type": "string"
                },
                "when": {
                  "type": "string"
                },
                "then": {
                  "type": "string"
                }
              }
            }
          },
          "depends_on": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^REQ-[0-9]{3}$"
            }
          }
        }
      }
    },
    "constraints": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "performance": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "response_time_p95_ms": { "type": "integer" },
            "throughput_rps": { "type": "integer" },
            "max_payload_kb": { "type": "integer" }
          }
        },
        "security": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["authentication_required", "pci_dss", "gdpr", "hipaa", "encrypt_at_rest", "encrypt_in_transit", "audit_logging"]
          }
        },
        "compatibility": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "browsers": { "type": "array", "items": { "type": "string" } },
            "platforms": { "type": "array", "items": { "type": "string", "enum": ["ios", "android", "web"] } },
            "min_os_versions": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "ios": { "type": "string" },
                "android": { "type": "string" }
              }
            }
          }
        },
        "accessibility": {
          "type": "string",
          "enum": ["wcag_2.1_aa", "wcag_2.1_aaa", "section_508"]
        },
        "localization": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "languages": { "type": "array", "items": { "type": "string" } },
            "rtl_support": { "type": "boolean" }
          }
        },
        "brands": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["BK", "PLK", "FHS", "TH"]
          }
        }
      }
    },
    "non_goals": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "description", "rationale"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^NG-[0-9]{3}$"
          },
          "description": {
            "type": "string"
          },
          "rationale": {
            "type": "string",
            "description": "Why is this explicitly out of scope?"
          }
        }
      }
    },
    "assumptions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "assumption", "risk_if_wrong"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^ASM-[0-9]{3}$"
          },
          "assumption": {
            "type": "string"
          },
          "risk_if_wrong": {
            "type": "string",
            "enum": ["low", "medium", "high"]
          },
          "validation_needed": {
            "type": "boolean"
          }
        }
      }
    },
    "edge_cases": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "scenario", "expected_behavior"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^EC-[0-9]{3}$"
          },
          "scenario": {
            "type": "string"
          },
          "expected_behavior": {
            "type": "string"
          },
          "related_requirement": {
            "type": "string",
            "pattern": "^REQ-[0-9]{3}$"
          }
        }
      }
    },
    "glossary": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      },
      "description": "Domain terms and their definitions"
    }
  }
}
