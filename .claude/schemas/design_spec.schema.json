{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "design_spec.schema.json",
  "title": "Design Specification",
  "description": "Structured output from Design Architect Agent - NO CODE, only architecture decisions",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "meta",
    "problem_spec_ref",
    "current_architecture",
    "architecture",
    "api_contracts",
    "data_models",
    "decisions",
    "implementation_guidelines",
    "testing_strategy",
    "security_considerations"
  ],
  "properties": {
    "meta": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "feature_id",
        "ticket_id",
        "created_at",
        "agent_version",
        "problem_spec_version",
        "codebase_location",
        "codebase_analyzed",
        "implementation_status"
      ],
      "properties": {
        "feature_id": {
          "type": "string",
          "pattern": "^FEAT-[0-9]{4}$"
        },
        "ticket_id": {
          "type": "string",
          "description": "Jira ticket ID (e.g. {{JIRA_PREFIX}}-1234, PROJ-5678)"
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        },
        "agent_version": {
          "type": "string",
          "const": "2.0"
        },
        "problem_spec_version": {
          "type": "string",
          "description": "Hash or version of input problem_spec"
        },
        "codebase_location": {
          "type": ["string", "null"],
          "description": "Absolute path to the codebase, or null for greenfield"
        },
        "codebase_analyzed": {
          "type": "boolean",
          "description": "True once existing codebase has been reviewed"
        },
        "implementation_status": {
          "type": "string",
          "enum": ["not_started", "in_progress", "partially_complete", "mostly_complete", "complete"]
        },
        "version": {
          "type": "string"
        },
        "iteration_history": {
          "type": "array",
          "items": { "type": "object" }
        },
        "brands": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["BK", "PLK", "FHS", "TH"]
          },
          "description": "{{ORG_SHORT}} brands this feature applies to"
        }
      }
    },
    "problem_spec_ref": {
      "type": "string",
      "description": "Reference to the problem_spec.json this design addresses"
    },
    "current_architecture": {
      "type": "object",
      "additionalProperties": false,
      "required": ["description", "existing_components", "existing_patterns", "integration_points"],
      "properties": {
        "description": { "type": "string" },
        "existing_components": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "file_path", "current_behavior", "modifications_needed"],
            "properties": {
              "name": { "type": "string" },
              "file_path": { "type": "string" },
              "current_behavior": { "type": "string" },
              "modifications_needed": { "type": "string" }
            }
          }
        },
        "existing_patterns": {
          "type": "array",
          "items": { "type": "string" }
        },
        "integration_points": {
          "type": "array",
          "items": { "type": "string" }
        },
        "implementation_status": {
          "type": "string",
          "enum": ["partially_complete", "mostly_complete", "complete"]
        }
      }
    },
    "architecture": {
      "type": "object",
      "additionalProperties": false,
      "required": ["pattern", "components", "data_flow"],
      "properties": {
        "pattern": {
          "type": "string",
          "enum": ["container_presenter", "mvvm", "mvc", "clean_architecture", "feature_sliced"],
          "description": "Primary architectural pattern"
        },
        "components": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "name", "type", "responsibility"],
            "properties": {
              "id": {
                "type": "string",
                "pattern": "^COMP-[0-9]{3}$"
              },
              "name": {
                "type": "string"
              },
              "type": {
                "type": "string",
                "enum": ["container", "presenter", "hook", "utility", "service", "context", "hoc", "molecule", "organism", "template"]
              },
              "responsibility": {
                "type": "string",
                "maxLength": 200
              },
              "dependencies": {
                "type": "array",
                "items": {
                  "type": "string",
                  "pattern": "^COMP-[0-9]{3}$"
                }
              },
              "file_path": {
                "type": "string",
                "description": "Relative path where this component should live"
              }
            }
          }
        },
        "data_flow": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["from", "to", "data", "trigger"],
            "properties": {
              "from": { "type": "string" },
              "to": { "type": "string" },
              "data": { "type": "string" },
              "trigger": { "type": "string" }
            }
          }
        }
      }
    },
    "api_contracts": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "graphql": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "queries": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["name", "description", "variables", "return_type"],
                "properties": {
                  "name": { "type": "string" },
                  "description": { "type": "string" },
                  "variables": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "additionalProperties": false,
                      "required": ["name", "type", "required"],
                      "properties": {
                        "name": { "type": "string" },
                        "type": { "type": "string" },
                        "required": { "type": "boolean" },
                        "default": { "type": "string" }
                      }
                    }
                  },
                  "return_type": { "type": "string" },
                  "cache_policy": {
                    "type": "string",
                    "enum": ["cache-first", "network-only", "cache-and-network", "no-cache"]
                  }
                }
              }
            },
            "mutations": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["name", "description", "variables", "return_type"],
                "properties": {
                  "name": { "type": "string" },
                  "description": { "type": "string" },
                  "variables": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "additionalProperties": false,
                      "required": ["name", "type", "required"],
                      "properties": {
                        "name": { "type": "string" },
                        "type": { "type": "string" },
                        "required": { "type": "boolean" }
                      }
                    }
                  },
                  "return_type": { "type": "string" },
                  "optimistic_response": { "type": "boolean" },
                  "cache_update": { "type": "string" }
                }
              }
            }
          }
        },
        "hooks": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "purpose", "parameters", "returns"],
            "properties": {
              "name": { "type": "string", "pattern": "^use[A-Z]" },
              "purpose": { "type": "string" },
              "parameters": {
                "type": "array",
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["name", "type"],
                  "properties": {
                    "name": { "type": "string" },
                    "type": { "type": "string" },
                    "optional": { "type": "boolean" }
                  }
                }
              },
              "returns": {
                "type": "object",
                "additionalProperties": false,
                "required": ["type"],
                "properties": {
                  "type": { "type": "string" },
                  "properties": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "additionalProperties": false,
                      "properties": {
                        "name": { "type": "string" },
                        "type": { "type": "string" }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "data_models": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "types": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "kind", "properties"],
            "properties": {
              "name": { "type": "string" },
              "kind": {
                "type": "string",
                "enum": ["interface", "type", "enum"]
              },
              "description": { "type": "string" },
              "properties": {
                "type": "array",
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["name", "type"],
                  "properties": {
                    "name": { "type": "string" },
                    "type": { "type": "string" },
                    "optional": { "type": "boolean" },
                    "description": { "type": "string" }
                  }
                }
              },
              "values": {
                "type": "array",
                "items": { "type": "string" },
                "description": "For enums only"
              }
            }
          }
        },
        "state_shape": {
          "type": "object",
          "description": "Shape of local/global state for this feature"
        }
      }
    },
    "decisions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "title", "context", "decision", "alternatives", "consequences"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^ADR-[0-9]{3}$"
          },
          "title": { "type": "string" },
          "context": { "type": "string" },
          "decision": { "type": "string" },
          "alternatives": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "option": { "type": "string" },
                "pros": { "type": "array", "items": { "type": "string" } },
                "cons": { "type": "array", "items": { "type": "string" } }
              }
            }
          },
          "consequences": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "positive": { "type": "array", "items": { "type": "string" } },
              "negative": { "type": "array", "items": { "type": "string" } },
              "risks": { "type": "array", "items": { "type": "string" } }
            }
          }
        }
      }
    },
    "implementation_guidelines": {
      "type": "object",
      "additionalProperties": false,
      "required": ["file_structure", "naming_conventions", "patterns_to_use", "patterns_to_avoid"],
      "properties": {
        "file_structure": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["path", "purpose"],
            "properties": {
              "path": { "type": "string" },
              "purpose": { "type": "string" },
              "component_id": { "type": "string" }
            }
          }
        },
        "naming_conventions": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "components": { "type": "string" },
            "hooks": { "type": "string" },
            "types": { "type": "string" },
            "constants": { "type": "string" },
            "test_files": { "type": "string" }
          }
        },
        "patterns_to_use": {
          "type": "array",
          "items": { "type": "string" }
        },
        "patterns_to_avoid": {
          "type": "array",
          "items": { "type": "string" }
        },
        "libraries": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "purpose"],
            "properties": {
              "name": { "type": "string" },
              "version": { "type": "string" },
              "purpose": { "type": "string" }
            }
          }
        }
      }
    },
    "testing_strategy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "unit_test_targets": {
          "type": "array",
          "items": { "type": "string" }
        },
        "integration_test_targets": {
          "type": "array",
          "items": { "type": "string" }
        },
        "e2e_scenarios": {
          "type": "array",
          "items": { "type": "string" }
        },
        "coverage_target": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        }
      }
    },
    "security_considerations": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["concern", "mitigation"],
        "properties": {
          "concern": { "type": "string" },
          "mitigation": { "type": "string" },
          "owasp_category": { "type": "string" }
        }
      }
    },
    "design_changes_log": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "version": { "type": "string" },
          "changes": {
            "type": "array",
            "items": { "type": "string" }
          },
          "rationale": { "type": "object" },
          "rejected_feedback": {
            "type": "array",
            "items": { "type": "object" }
          }
        }
      }
    },
    "flags": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "type": { "type": "string" },
          "requirement_id": { "type": "string" },
          "issue": { "type": "string" },
          "suggestion": { "type": "string" }
        }
      }
    },
    "approval_status": { "type": "string" },
    "ready_for_implementation": { "type": "boolean" },
    "iteration_number": { "type": "integer" },
    "previous_review_addressed": { "type": "boolean" },
    "escalation_required": { "type": "boolean" },
    "human_review_needed": { "type": "boolean" },
    "summary_for_human": { "type": "string" },
    "gaps_identified": { "type": "array", "items": { "type": "object" } },
    "enhancements_needed": { "type": "array", "items": { "type": "object" } }
  }
}
