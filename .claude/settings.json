{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(gh pr create*)",
            "command": "bash scripts/security-scan.sh"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(npm run *)",
      "Bash(npm install *)",
      "Bash(pytest *)",
      "Bash(pip install *)",
      "Bash(git status)",
      "Bash(git diff)",
      "Bash(git log *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Read(src/**)",
      "Read(tests/**)",
      "Read(docs/**)",
      "Read(.claude/**)",
      "Write(src/**)",
      "Write(tests/**)",
      "Write(docs/**)",
      "Edit(src/**)",
      "Edit(tests/**)",
      "Edit(docs/**)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(git push --force *)",
      "Bash(git reset --hard *)",
      "Bash(git clean -f *)",
      "Write(.env)",
      "Write(**/*.env)",
      "Write(**/.env.*)",
      "Edit(.env)",
      "Edit(**/*.env)",
      "Write(All Demo Files-20260325T171750Z-3-001/**)",
      "Edit(All Demo Files-20260325T171750Z-3-001/**)"
    ]
  },
  "autoMemoryEnabled": true
}
